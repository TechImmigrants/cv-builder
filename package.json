{
  "name": "cv-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Open source CV builder for tech professionals. Paste a job description, get a tailored resume.",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo test",
    "eval": "turbo eval",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
