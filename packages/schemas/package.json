{
  "name": "@cv-builder/schemas",
  "version": "0.1.0",
  "description": "Zod schemas and inferred types — the validated contract shared across CV Builder",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "cv",
    "resume",
    "zod",
    "schema",
    "types"
  ],
  "license": "MIT"
}
